{
  "systemSetup": [],
  "templateName": "custom",
  "projectDependencies": [
    {
      "name": "Install Dependencies",
      "command": "npm install"
    }
  ],
  "codeChecks": [
    {
      "name": "Run Tests",
      "command": "npm test -- --watchAll=false --passWithNoTests"
    }
  ],
  "buildSteps": [
    {
      "name": "Build Project",
      "command": "npm run build"
    }
  ],
  "runStep": [
    {
      "name": "Run Dev Server",
      "command": "HOST=0.0.0.0 DANGEROUSLY_DISABLE_HOST_CHECK=true PORT=3000 npm start -- --port 3000",
      "port": "3000"
    }
  ],
  "deploySteps": [],
  "cleanupFiles": [
    "node_modules",
    "build",
    ".env"
  ],
  "packageManager": "npm",
  "envPaths": [
    {
      "name": "default",
      "path": ".env"
    }
  ]
}
